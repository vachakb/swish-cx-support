# Server
PORT=8787

# LLM provider: "gemini" or "mock".
# Leave LLM_PROVIDER empty to auto-select: gemini if GEMINI_API_KEY is set, else mock.
LLM_PROVIDER=
GEMINI_API_KEY=
# Optional model overrides (Gemini 3.x — 2.5 is deprecated). Re-verify ids at ai.google.dev.
GEMINI_MODEL_FAST=
GEMINI_MODEL_SMART=
GEMINI_MODEL_VISION=

# Database (libSQL / local SQLite file)
DATABASE_URL=file:./data/swish.db

# Rate limiting (in-process, per client IP). Leave ENABLED blank to keep it on; "false" disables it.
RATE_LIMIT_ENABLED=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GLOBAL=200
RATE_LIMIT_CHAT=30

# WhatsApp Cloud API — leave ACCESS_TOKEN + PHONE_NUMBER_ID blank for simulator mode.
# Fill them (+ point Meta's webhook at /api/whatsapp/webhook with the verify token) to go live.
WHATSAPP_VERIFY_TOKEN=swish-verify
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_BASE=https://graph.facebook.com/v21.0
